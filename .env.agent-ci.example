# Copy this file to .env.agent-ci for machine-local Agent CI overrides.
# Agent CI loads .env.agent-ci automatically.

# Set this if your repo has no origin remote and Agent CI prints
# `No such remote 'origin'` while trying to infer owner/repo.
# GITHUB_REPO=your-org/your-repo

# Set this if runner containers need a different hostname to reach the host.
# AGENT_CI_DTU_HOST=host.docker.internal

# Set this if Agent CI needs a different Docker socket than /var/run/docker.sock.
# AGENT_CI_DOCKER_SOCKET=/var/run/docker.sock
